<title>Galería · Portafolio Streamlit</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Mono:wght@300;400&family=Cormorant+Garamond:wght@300;400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a08;
    --surface: #111110;
    --card: #161614;
    --border: #2a2a26;
    --gold: #c9a84c;
    --gold-light: #e2c278;
    --cream: #f0ead8;
    --muted: #6b6b5e;
    --accent: #8b4513;
    --white: #f5f0e8;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--white);
    font-family: 'DM Mono', monospace;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Grain overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1000;
    opacity: 0.4;
  }

  /* Header */
  header {
    padding: 80px 60px 40px;
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  .header-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
  }

  .gallery-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.3em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 400;
    line-height: 1.05;
    color: var(--cream);
    letter-spacing: -0.02em;
  }

  h1 em {
    font-style: italic;
    color: var(--gold-light);
  }

  .header-meta {
    text-align: right;
    flex-shrink: 0;
  }

  .count-label {
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .count-number {
    font-family: 'Playfair Display', serif;
    font-size: 4rem;
    color: var(--border);
    line-height: 1;
    font-style: italic;
  }

  /* Divider line */
  .gold-line {
    width: 60px;
    height: 1px;
    background: var(--gold);
    margin: 20px 0;
  }

  /* Filter bar */
  .filter-bar {
    padding: 24px 60px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .filter-bar-inner {
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .filter-label {
    font-size: 9px;
    letter-spacing: 0.3em;
    color: var(--muted);
    text-transform: uppercase;
    flex-shrink: 0;
  }

  .tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tag {
    padding: 5px 14px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.15em;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
  }

  .tag:hover, .tag.active {
    border-color: var(--gold);
    color: var(--gold);
    background: rgba(201,168,76,0.06);
  }

  /* Gallery grid */
  .gallery {
    padding: 60px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2px;
  }

  /* Card */
  .card {
    position: relative;
    background: var(--card);
    border: 1px solid var(--border);
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.3s;
    text-decoration: none;
    display: block;
    animation: fadeUp 0.6s both;
  }

  .card:hover {
    border-color: var(--gold);
    z-index: 2;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* stagger */
  .card:nth-child(1) { animation-delay: 0.05s; }
  .card:nth-child(2) { animation-delay: 0.10s; }
  .card:nth-child(3) { animation-delay: 0.15s; }
  .card:nth-child(4) { animation-delay: 0.20s; }
  .card:nth-child(5) { animation-delay: 0.25s; }
  .card:nth-child(6) { animation-delay: 0.30s; }
  .card:nth-child(7) { animation-delay: 0.35s; }
  .card:nth-child(8) { animation-delay: 0.40s; }
  .card:nth-child(9) { animation-delay: 0.45s; }
  .card:nth-child(10){ animation-delay: 0.50s; }
  .card:nth-child(11){ animation-delay: 0.55s; }
  .card:nth-child(12){ animation-delay: 0.60s; }
  .card:nth-child(13){ animation-delay: 0.65s; }
  .card:nth-child(14){ animation-delay: 0.70s; }
  .card:nth-child(15){ animation-delay: 0.75s; }
  .card:nth-child(16){ animation-delay: 0.80s; }

  /* Preview area */
  .preview {
    width: 100%;
    height: 220px;
    position: relative;
    overflow: hidden;
    background: var(--surface);
  }

  .preview iframe {
    width: 100%;
    height: 100%;
    border: none;
    pointer-events: none;
    transform: scale(1);
    transform-origin: top left;
    opacity: 0.85;
    transition: opacity 0.4s;
  }

  .card:hover .preview iframe {
    opacity: 1;
  }

  /* Overlay shimmer on hover */
  .preview::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(201,168,76,0.08) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }
  .card:hover .preview::after { opacity: 1; }

  /* Placeholder for iframe load */
  .preview-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    background: var(--surface);
  }

  .preview-placeholder .icon {
    font-size: 2.5rem;
    opacity: 0.4;
  }

  .preview-placeholder .loading-text {
    font-size: 9px;
    letter-spacing: 0.25em;
    color: var(--muted);
    text-transform: uppercase;
  }

  /* Number badge */
  .badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 9px;
    letter-spacing: 0.2em;
    padding: 3px 8px;
    font-family: 'DM Mono', monospace;
    z-index: 2;
  }

  /* Visit btn overlay */
  .visit-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10,10,8,0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.25s;
    z-index: 3;
  }

  .card:hover .visit-overlay { opacity: 1; }

  .visit-btn {
    border: 1px solid var(--gold);
    color: var(--gold);
    padding: 10px 28px;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    background: transparent;
    transition: all 0.2s;
  }

  .visit-btn:hover {
    background: var(--gold);
    color: var(--bg);
  }

  /* Card footer */
  .card-footer {
    padding: 18px 20px 20px;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }

  .card-info { flex: 1; }

  .card-category {
    font-size: 9px;
    letter-spacing: 0.25em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--cream);
    line-height: 1.2;
    letter-spacing: 0.01em;
  }

  .card-url {
    font-size: 9px;
    color: var(--muted);
    margin-top: 5px;
    letter-spacing: 0.05em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 200px;
  }

  .arrow-icon {
    color: var(--gold);
    font-size: 1.1rem;
    margin-top: 4px;
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  .card:hover .arrow-icon { transform: translate(3px, -3px); }

  /* Footer */
  footer {
    border-top: 1px solid var(--border);
    padding: 40px 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: var(--muted);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-brand {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    color: var(--gold);
    font-style: italic;
    letter-spacing: 0.05em;
    text-transform: none;
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); }

  @media (max-width: 768px) {
    header { padding: 40px 24px 32px; }
    .header-inner { flex-direction: column; align-items: flex-start; }
    .header-meta { text-align: left; }
    .filter-bar { padding: 16px 24px; }
    .gallery { padding: 32px 24px; }
    .grid { grid-template-columns: 1fr; gap: 2px; }
    footer { padding: 32px 24px; }
    .footer-inner { flex-direction: column; gap: 12px; align-items: flex-start; }
  }
</style>
</head>
